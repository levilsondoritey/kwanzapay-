{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/script.js", "dest": "/public/script.js" },
    { "src": "/index.html", "dest": "/public/index.html" },
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "/(.*\\.html)", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
